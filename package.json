{
  "name": "loopany-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Loopany — multi-user scheduled-loop manager. Server schedules/stores/auths; execution is BYOA (claude-code on the user's own machine).",
  "type": "module",
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @loopany/server dev",
    "build": "pnpm --filter @loopany/server build",
    "start": "pnpm --filter @loopany/server start",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
