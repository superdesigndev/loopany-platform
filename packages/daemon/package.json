{
  "name": "@crewlet/loopany",
  "version": "0.16.0",
  "description": "Loopany daemon — runs on your machine, connects to a Loopany server, and executes scheduled loops via your local claude-code. One binary, two roles (daemon / loop callback).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/superdesigndev/loopany-platform.git",
    "directory": "packages/daemon"
  },
  "type": "module",
  "bin": {
    "loopany": "dist/cli.js"
  },
  "files": [
    "dist",
    "skill",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node scripts/sync-skill.mjs && node scripts/copy-runtime-assets.mjs && tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "node scripts/sync-skill.mjs && node scripts/copy-runtime-assets.mjs && tsc"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "mcporter": "0.12.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "4.1.9"
  }
}
