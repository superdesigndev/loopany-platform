{
  "name": "@crewlet/loopany",
  "version": "0.5.0",
  "description": "LoopAny daemon — runs on your machine, connects to a LoopAny server, and executes scheduled loops via your local claude-code. One binary, two roles (daemon / loop callback).",
  "type": "module",
  "bin": {
    "loopany": "dist/cli.js"
  },
  "files": [
    "dist",
    "skill"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node scripts/sync-skill.mjs && tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "node scripts/sync-skill.mjs && tsc"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "4.1.9"
  }
}
