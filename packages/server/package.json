{
  "name": "@loopany/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Loopany server — TanStack Start UI + in-process scheduler + machine WS gateway + agent-api + Better Auth. Zero code-exec, zero LLM (execution is BYOA on user machines).",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "drizzle-kit migrate && node .output/server/index.mjs",
    "routes:generate": "tsr generate",
    "typecheck": "tsr generate && tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@base-ui/react": "^1.6.0",
    "@better-auth/drizzle-adapter": "^1.6.19",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@lezer/highlight": "^1.2.3",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "@uiw/codemirror-themes": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "better-auth": "^1.6.19",
    "better-sqlite3": "^12.11.1",
    "croner": "^10.0.1",
    "diff": "^9.0.0",
    "dompurify": "^3.4.11",
    "drizzle-orm": "^0.45.2",
    "html-react-parser": "^6.1.3",
    "marked": "^18.0.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-cli": "1.167.17",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "nitro": "3.0.260610-beta",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
